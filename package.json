  "scripts": {
    "cli": "node --experimental-strip-types apps/cli/src/index.ts",
    "test": "node --experimental-strip-types --test apps/cli/src/commands/root.test.ts apps/cli/src/router.test.ts apps/cli/src/interactive.test.ts apps/cli/src/package-scripts.test.ts packages/config/src/config.test.ts packages/chains/src/registry.test.ts packages/wallet/src/wallet.test.ts packages/rpc/src/manager.test.ts packages/tx/src/core.test.ts packages/tx/src/simulate.test.ts tests/e2e/core-commands.test.ts packages/contracts/src/contracts.test.ts tests/e2e/deploy-contract.test.ts tests/e2e/contract-interaction.test.ts packages/debug/src/debug.test.ts tests/e2e/debug-tx.test.ts packages/memory/src/memory.test.ts packages/agent/src/agent.test.ts tests/e2e/agent-workflows.test.ts packages/monitor/src/monitor.test.ts tests/e2e/monitoring.test.ts packages/platform/src/platform.test.ts tests/e2e/team-mode.test.ts",
    "test:platform": "node --experimental-strip-types --test packages/platform/src/platform.test.ts tests/e2e/team-mode.test.ts",
    "test:integration": "node --experimental-strip-types --test tests/integration/balance-real-rpc.test.ts tests/integration/simulate-real-rpc.test.ts tests/integration/estimate-gas-real-rpc.test.ts tests/integration/trace-real-rpc.test.ts tests/integration/deploy-real-rpc.test.ts tests/integration/interact-contract-real-rpc.test.ts tests/integration/fork-chain-real-rpc.test.ts",
    "test:monitor": "node --experimental-strip-types --test packages/monitor/src/monitor.test.ts tests/e2e/monitoring.test.ts",
    "test:chains": "node --experimental-strip-types --test packages/chains/src/registry.test.ts",
    "test:config": "node --experimental-strip-types --test packages/config/src/config.test.ts",
    "test:contracts": "node --experimental-strip-types --test packages/contracts/src/contracts.test.ts tests/e2e/deploy-contract.test.ts tests/e2e/contract-interaction.test.ts",
    "test:core-commands": "node --experimental-strip-types --test packages/tx/src/core.test.ts tests/e2e/core-commands.test.ts",
    "test:debug": "node --experimental-strip-types --test packages/debug/src/debug.test.ts tests/e2e/debug-tx.test.ts",
    "test:memory": "node --experimental-strip-types --test packages/memory/src/memory.test.ts packages/config/src/config.test.ts",
    "test:rpc": "node --experimental-strip-types --test packages/rpc/src/manager.test.ts",
    "test:root": "node --experimental-strip-types --test apps/cli/src/commands/root.test.ts apps/cli/src/router.test.ts apps/cli/src/interactive.test.ts apps/cli/src/package-scripts.test.ts",
    "test:studio": "node --experimental-strip-types --test packages/contracts/src/contracts.test.ts packages/tx/src/simulate.test.ts tests/e2e/contract-interaction.test.ts",
    "test:tx": "node --experimental-strip-types --test packages/tx/src/core.test.ts packages/tx/src/simulate.test.ts",
    "test:wallet": "node --experimental-strip-types --test packages/wallet/src/wallet.test.ts",
    "test:agent": "node --experimental-strip-types --test packages/agent/src/agent.test.ts tests/e2e/agent-workflows.test.ts",
    "typecheck": "node --experimental-strip-types apps/cli/src/index.ts --help"
  },
  "dependencies": {
    "viem": "^2.48.8"
  }
}
